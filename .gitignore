# Gavin's .gitignore
# Keep sensitive data out of version control

# Credentials and tokens
*.plist
launch_*.sh

# Sensitive environment
.env
.env.local

# Large logs
gavin.log
*.log

# Runtime files
*.pid
nohup.out

# Python cache
__pycache__/
*.pyc
*.pyo
.DS_Store

# Inbox (transient files)
inbox/
