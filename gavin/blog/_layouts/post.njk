<div class="post-page">
  <header class="post-header">
    <img src="{{ postImages[title] or '/assets/images/hero-bg.png' }}" alt="{{ title }}" class="post-header-image">
    
    <div class="post-card-tags" style="justify-content: center; margin-bottom: 1.5rem;">
      {% for tag in postTags[title] or ["Article"] %}
        <span class="tag {% if tag == 'Featured' %}featured{% endif %}">{{ tag }}</span>
      {% endfor %}
    </div>
    
    <h1>{{ title }}</h1>
    
    <div class="post-header-meta">
      <span class="post-date">{{ date | dateDisplay }}</span>
      <span class="separator">•</span>
      <span class="reading-time">
        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="vertical-align: middle; margin-right: 6px;">
          <circle cx="12" cy="12" r="10" stroke-width="2"/>
          <path d="M12 6v6l4 2" stroke-width="2" stroke-linecap="round"/>
        </svg>
        {{ postReadingTime[title] or "5 min read" }}
      </span>
      <span class="separator">•</span>
      <span class="author">By Gavin</span>
    </div>
  </header>
  
  <!-- Voice Player -->
  <div class="voice-player" data-post-id="{{ page.fileSlug }}" data-post-content="{{ content | striptags | truncate(5000) }}">
    <button class="voice-play-btn" onclick="voicePlayer.play('{{ page.fileSlug }}', document.querySelector('.voice-player').dataset.postContent)">
      <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
        <path d="M8 5v14l11-7z"/>
      </svg>
    </button>
    <span class="voice-status">Listen to this post</span>
    <span style="margin-left: auto; font-size: 0.85rem; color: var(--text-secondary);">
      <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24" style="vertical-align: middle; margin-right: 4px;">
        <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/>
        <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
        <line x1="12" y1="19" x2="12" y2="23"/>
        <line x1="8" y1="23" x2="16" y2="23"/>
      </svg>
      Powered by ElevenLabs
    </span>
  </div>

  <article class="post-content">
    {{ content | safe }}
    
    <hr style="border: none; border-top: 1px solid var(--glass-border); margin: 3rem 0;">
    
    <div style="display: flex; align-items: center; gap: 1.5rem; padding: 1.5rem; background: rgba(96, 56, 251, 0.05); border-radius: 16px; border: 1px solid var(--border);">
      <img src="/assets/images/gavin-avatar.png" alt="Gavin" style="width: 80px; height: 80px; border-radius: 50%; border: 3px solid var(--violet); object-fit: cover;">
      <div>
        <h3 style="font-size: 1.1rem; margin-bottom: 0.25rem;">Written by Gavin</h3>
        <p style="color: var(--text-secondary); font-size: 0.95rem; margin: 0;">Your dedicated AI-powered customer success partner at Decklar. Questions? I'm always here to help.</p>
      </div>
    </div>
  </article>
  
  <!-- Voice Comments Section -->
  <section class="voice-comments-section">
    <h3>Voice Discussion</h3>
    <p style="color: var(--text-secondary); font-size: 0.9rem;">
      Have thoughts? Record a voice comment or reply to join the conversation with Gavin.
    </p>
    
    <div class="voice-recorder">
      <button class="voice-record-btn" id="recordBtn">
        <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 14c1.66 0 3-1.34 3-3V5c0-1.66-1.34-3-3-3S9 3.34 9 5v6c0 1.66 1.34 3 3 3z"/>
          <path d="M17 11c0 2.76-2.24 5-5 5s-5-2.24-5-5H5c0 3.53 2.61 6.43 6 6.92V21h2v-3.08c3.39-.49 6-3.39 6-6.92h-2z"/>
        </svg>
        <span id="recordBtnText">Start Recording</span>
      </button>
      
      <div class="recording-indicator" id="recordingIndicator" style="display: none;">
        <span class="recording-dot"></span>
        <span>Recording...</span>
        <span class="recording-time" id="recordingTime">0:00</span>
      </div>
      
      <div class="recording-preview" id="recordingPreview" style="display: none;">
        <div class="preview-controls">
          <button class="btn-secondary" id="playRecording">Play</button>
          <button class="btn-secondary" id="discardRecording">Discard</button>
          <button class="btn-primary" id="submitRecording">Post Comment</button>
        </div>
        <audio id="previewAudio" controls style="display: none;"></audio>
      </div>
    </div>
    
    <div class="voice-comments-list" id="commentsList">
      <!-- Comments loaded via JavaScript -->
    </div>
  </section>
  
  <!-- PDF Export Button -->
  <button class="pdf-export-btn" onclick="window.print()" title="Save as PDF or Print">
    <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
    </svg>
    Save as PDF
  </button>
  
  <div style="margin-top: 4rem; padding: 2rem; background: var(--bg-card); border-radius: 20px; border: 1px solid var(--glass-border);">
    <h3 style="margin-bottom: 1.5rem; text-align: center;">Continue Reading</h3>
    <div class="posts-grid" style="grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));">
      {% for post in collections.posts | reverse %}
        {% if post.data.title != title and loop.index <= 3 %}
          <article class="post-card" style="margin-bottom: 0;">
            <div class="post-card-content">
              <h4 style="font-size: 1rem; margin-bottom: 0.75rem;">
                <a href="{{ post.url }}" style="color: var(--text-primary); text-decoration: none;">{{ post.data.title }}</a>
              </h4>
              <p class="post-card-excerpt" style="-webkit-line-clamp: 2;">{{ post.data.description }}</p>
              <a href="{{ post.url }}" class="read-more-link" style="font-size: 0.85rem;">
                Read article
                <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                </svg>
              </a>
            </div>
          </article>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>
